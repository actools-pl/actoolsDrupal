# Cloudflare Tunnel configuration template
# Copy to /etc/cloudflared/config.yml and fill in your tunnel ID
#
# Setup: see modules/network/cloudflare-setup.md

tunnel: YOUR_TUNNEL_ID
credentials-file: /home/actools/.cloudflared/YOUR_TUNNEL_ID.json

ingress:
  - hostname: YOUR_DOMAIN
    service: http://localhost:80
  - hostname: www.YOUR_DOMAIN
    service: http://localhost:80
  - service: http_status:404
