# =============================================================================
# Actools — Drupal 11 Enterprise Installer
# Dedicated Worker Container · Multi-Provider S3 · XeLaTeX in Container
# =============================================================================
#
# REQUIRED: Set BASE_DOMAIN and DRUPAL_ADMIN_EMAIL before running.
#
# Everything else has a sensible default or auto-generates.
# Minimum viable config: set BASE_DOMAIN + DRUPAL_ADMIN_EMAIL, run installer.
# =============================================================================

# -- Domain & TLS -------------------------------------------------------------
BASE_DOMAIN=example.com
DRUPAL_ADMIN_EMAIL=admin@example.com

# -- Site Identity ------------------------------------------------------------
# SITE_NAME: Drupal site name shown in the admin and browser title.
# Defaults to "AcTools" if left blank.
SITE_NAME=

# -- Environment Mode ---------------------------------------------------------
# production-isolated = prod only (recommended for production)
# all-in-one          = dev, stg, prod on same server (testing / staging only)
ENVIRONMENT_MODE=production-isolated

# -- Database -----------------------------------------------------------------
# Leave blank to auto-generate a secure password (recommended).
# Set explicitly only if you need a specific password or are reinstalling.
DB_ROOT_PASS=

# -- Drupal Admin Account -----------------------------------------------------
DRUPAL_ADMIN_USER=admin
# Leave blank to auto-generate. Password is shown after install completes.
DRUPAL_ADMIN_PASS=

# -- Versions -----------------------------------------------------------------
# DRUPAL_VERSION supports three formats:
#   11       → latest stable 11.x (recommended)
#   11.3     → latest 11.3.x patch
#   11.3.5   → exact version
DRUPAL_VERSION=11
PHP_VERSION=8.3
MARIADB_VERSION=11.4

# -- PHP Resource Limits ------------------------------------------------------
PHP_MEMORY_LIMIT=512m
WORKER_MEMORY_LIMIT=2g
PHP_UPLOAD_MAX=256m
PHP_MAX_EXEC=300
COMPOSER_PROCESS_TIMEOUT=600

# -- OPcache ------------------------------------------------------------------
PHP_OPCACHE_ENABLE=1
PHP_OPCACHE_MEMORY=256
PHP_OPCACHE_MAX_FILES=20000
PHP_OPCACHE_VALIDATE_TIMESTAMPS=1

# -- MariaDB ------------------------------------------------------------------
DB_MEMORY_LIMIT=2g
# INNODB_BUFFER_POOL: set to ~50-70% of available RAM.
# Default 1G works well for Hetzner CX22 (4GB RAM).
INNODB_BUFFER_POOL=1G
INNODB_LOG_FILE_SIZE=256M
MARIADB_MAX_CONNECTIONS=100

# -- Redis --------------------------------------------------------------------
ENABLE_REDIS=true
REDIS_MEMORY_LIMIT=256m

# -- XeLaTeX Mode -------------------------------------------------------------
# local  = XeLaTeX runs inside actools_worker:latest (default, no setup needed)
# remote = XeLaTeX runs on a remote HTTP service (set XELATEX_ENDPOINT below)
XELATEX_MODE=local
XELATEX_ENDPOINT=

# -- S3 Storage ---------------------------------------------------------------
# Set ENABLE_S3_STORAGE=false to use local container filesystem (default).
# STORAGE_PROVIDER: aws | backblaze | wasabi | custom
# Auto-detected from S3_ENDPOINT_URL if left blank.
ENABLE_S3_STORAGE=false
STORAGE_PROVIDER=
# Examples:
#   STORAGE_PROVIDER=backblaze + S3_ENDPOINT_URL=https://s3.us-west-000.backblazeb2.com
#   STORAGE_PROVIDER=aws + AWS_REGION=eu-west-1
#   STORAGE_PROVIDER=custom + S3_ENDPOINT_URL=https://ACCOUNT.r2.cloudflarestorage.com

# Common credentials
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Bucket name
S3_BUCKET=

# AWS only
AWS_REGION=us-east-1

# Non-AWS endpoint (Backblaze, Wasabi, MinIO, DigitalOcean Spaces, Cloudflare R2, etc.)
S3_ENDPOINT_URL=

# Optional CDN hostname for public file delivery (e.g. files.yourdomain.com)
ASSET_CDN_HOST=

# -- Swap ---------------------------------------------------------------------
ENABLE_SWAP=true
SWAP_SIZE=4G

# -- Environments (all-in-one mode only) --------------------------------------
# Only used when ENVIRONMENT_MODE=all-in-one. Leave as prod for production.
ENVIRONMENTS=prod

# -- Extra Composer Packages --------------------------------------------------
# Space-separated list of extra Drupal modules to install.
# Example: EXTRA_PACKAGES=drupal/admin_toolbar drupal/pathauto drupal/metatag
EXTRA_PACKAGES=

# -- Backup -------------------------------------------------------------------
BACKUP_RETENTION_DAYS=7
# RCLONE_REMOTE: rclone destination for off-site backup upload.
# Example: RCLONE_REMOTE=b2:my-bucket/backups
# Leave empty to skip off-site upload (backups stored locally only).
RCLONE_REMOTE=

# -- Observability (optional) -------------------------------------------------
ENABLE_CADVISOR=false

# -- Notification Webhook (optional) -----------------------------------------
# POST request sent on install completion and health alerts.
# Example: NOTIFY_WEBHOOK=https://hooks.slack.com/services/T000/B000/xxxx
NOTIFY_WEBHOOK=
