# =============================================================================
# Actools — Drupal 11 Enterprise Installer v9.2
# Dedicated Worker Container · Multi-Provider S3 · XeLaTeX in Container
# =============================================================================
#
# REQUIRED: Set BASE_DOMAIN and DRUPAL_ADMIN_EMAIL before running.
#
# DB_ROOT_PASS: Set a strong password here before first install.
#   DO NOT leave blank -- the installer will not auto-generate if set -u is active.
#   Recommended: openssl rand -base64 18 | tr -dc 'A-Za-z0-9' | head -c 22
#
# DRUPAL_ADMIN_PASS: Set your desired admin password, or leave blank to auto-generate.
#
# S3 credentials are passed as Docker environment variables and injected into
# settings.php via getenv(). They are NEVER written to Drupal's config system.
#
# XeLaTeX runs inside the dedicated worker container (actools_worker:latest),
# built from Dockerfile.worker at install time. No host toolchain needed.
# =============================================================================

# -- Domain & TLS -------------------------------------------------------------
BASE_DOMAIN=example.com
DRUPAL_ADMIN_EMAIL=admin@example.com

# -- Environment Mode ---------------------------------------------------------
# production-isolated = prod only (recommended for production)
# all-in-one          = dev, stg, prod on same server (testing / staging only)
ENVIRONMENT_MODE=production-isolated

# -- Database -----------------------------------------------------------------
# Set a strong password here. Do NOT leave blank.
# Generate one: openssl rand -base64 18 | tr -dc 'A-Za-z0-9' | head -c 22
DB_ROOT_PASS=

# -- Drupal Admin Account -----------------------------------------------------
DRUPAL_ADMIN_USER=admin
DRUPAL_ADMIN_PASS=

# -- Versions -----------------------------------------------------------------
PHP_VERSION=8.3
MARIADB_VERSION=11.4
DRUPAL_VERSION=11

# -- PHP Resource Limits ------------------------------------------------------
PHP_MEMORY_LIMIT=512m
WORKER_MEMORY_LIMIT=2g
PHP_UPLOAD_MAX=256m
PHP_MAX_EXEC=300
COMPOSER_PROCESS_TIMEOUT=600

# -- OPcache ------------------------------------------------------------------
PHP_OPCACHE_ENABLE=1
PHP_OPCACHE_MEMORY=256
PHP_OPCACHE_MAX_FILES=20000
PHP_OPCACHE_VALIDATE_TIMESTAMPS=1

# -- MariaDB ------------------------------------------------------------------
DB_MEMORY_LIMIT=2g
INNODB_BUFFER_POOL=1G
INNODB_LOG_FILE_SIZE=256M
MARIADB_MAX_CONNECTIONS=100

# -- Redis --------------------------------------------------------------------
ENABLE_REDIS=true
REDIS_MEMORY_LIMIT=256m

# -- XeLaTeX Mode -------------------------------------------------------------
# local  = XeLaTeX runs inside actools_worker:latest (default)
# remote = XeLaTeX runs on a remote HTTP service (set XELATEX_ENDPOINT below)
XELATEX_MODE=local
XELATEX_ENDPOINT=

# -- S3 Storage ---------------------------------------------------------------
# Set ENABLE_S3_STORAGE=false to use local container filesystem storage.
# STORAGE_PROVIDER: aws | backblaze | wasabi | custom
# Auto-detected from S3_ENDPOINT_URL if left blank.
ENABLE_S3_STORAGE=false
STORAGE_PROVIDER=

# Common credentials
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Bucket name
S3_BUCKET=

# AWS only
AWS_REGION=us-east-1

# Non-AWS endpoint (Backblaze, Wasabi, MinIO, DigitalOcean Spaces, etc.)
S3_ENDPOINT_URL=

# Optional CDN hostname for public file delivery
ASSET_CDN_HOST=

# -- Swap ---------------------------------------------------------------------
ENABLE_SWAP=true
SWAP_SIZE=4G

# -- Environments (all-in-one mode only) --------------------------------------
ENVIRONMENTS=prod

# -- Extra Composer Packages --------------------------------------------------
EXTRA_PACKAGES=

# -- Backup -------------------------------------------------------------------
BACKUP_RETENTION_DAYS=7
RCLONE_REMOTE=

# -- Observability (optional) -------------------------------------------------
ENABLE_CADVISOR=false

# -- Notification Webhook (optional) -----------------------------------------
NOTIFY_WEBHOOK=
